<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HalliSanthe" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/market_orange</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/market_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/market_primary_dark</item>
        <item name="colorSecondary">@color/market_accent</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSecondaryContainer">@color/surface_muted</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="colorSurface">@color/surface_warm</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
    </style>

    <style name="Theme.HalliSanthe.Splash" parent="Theme.HalliSanthe">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/market_orange_dark</item>
    </style>

    <style name="Theme.HalliSanthe.Detail" parent="Theme.HalliSanthe">
        <item name="android:statusBarColor">@color/market_orange_dark</item>
    </style>

</resources>
